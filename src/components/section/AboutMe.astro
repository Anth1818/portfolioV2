---
import LayoutSection from "../../layouts/LayoutSection.astro";
import Badges from "../Badges.astro";
import photo from "src/assets/foto-linkedin.jpg"
import { MotionSection } from "../ui/motion";

const {lang} = Astro.props

const content = {
  es: {
    titleSection: "Sobre mí",
    title: "Desarrollador Web",
    description: "Mi objetivo es aprender y crecer continuamente en el campo del desarrollo de software, contribuyendo a proyectos que generen un impacto positivo en los usuarios y la comunidad, y ser parte de un equipo que valore la colaboración y la innovación.",
    button: "Mira mis proyectos"
  },
  en: {
    titleSection: "About Me",
    title: "Web Developer",
    description: "My goal is to continuously learn and grow in the field of software development, contributing to projects that make a positive impact on users and the community, and to be part of a team that values collaboration and innovation.",
    button: "Look at my projects"
  }
}
---

<LayoutSection title={lang === "es" ? content.es.titleSection : content.en.titleSection} colorSection="section-primary" id="about">
  <MotionSection client:load className="container mx-auto max-w-6xl">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-24">
      <!-- Photo -->
      <div class="relative group shrink-0">
        <div class="absolute -inset-4 orange-gradient rounded-3xl blur opacity-25 group-hover:opacity-40 transition duration-500"></div>
        <div class="relative bg-neutral-900 rounded-3xl overflow-hidden aspect-auto w-64 md:w-80 shadow-2xl">
          <img
            src={photo.src}
            alt={lang === "es" ? "Foto de perfil" : "Profile photo"}
            class="w-full h-full object-cover grayscale-[0.2] hover:grayscale-0 transition-all duration-700 hover:scale-105"
          />
        </div>
      </div>

      <!-- Description -->
      <div class="flex-1 text-center lg:text-left">
        <h3 class="text-3xl md:text-4xl font-bold mb-4 text-gradient">
          {lang === "es" ? content.es.title : content.en.title}
        </h3>
        
        <div class="flex flex-wrap justify-center lg:justify-start gap-3 mt-4 mb-8">
            <Badges text="HTML" />
            <Badges text="CSS" />
            <Badges text="TypeScript" />
            <Badges text="React" />
            <Badges text="Astro" />
            <Badges text="Node.js" />
            <!-- <Badges text="Express" /> -->
        </div>

        <p class="text-lg md:text-xl text-neutral-300 leading-relaxed mb-10 max-w-2xl">
          {lang === "es" ? content.es.description : content.en.description}
        </p>

        <a
          href="#projects"
          class="inline-block px-10 py-4 rounded-full glass hover:bg-white/10 text-white font-bold text-lg transition-all duration-300 border border-white/20 hover:border-white/40 shadow-lg shadow-black/20"
        >
          {lang === "es" ? content.es.button : content.en.button}
        </a>
      </div>
    </div>
  </MotionSection>
</LayoutSection>
