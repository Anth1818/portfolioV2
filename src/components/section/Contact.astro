---
import { Icon } from "astro-icon/components";
import LayoutSection from "../../layouts/LayoutSection.astro";
import ContactForm from "../ContactForm";
import { MotionSection } from "../ui/motion";

const { lang } = Astro.props;

const contactInfo = {
  linkedin: {
    label: "Linkedin",
    url: "linkedin.com/in/anthony-ruiz-7820b7161/",
    href: "https://www.linkedin.com/in/anthony-ruiz-7820b7161/"
  },
  github: {
    label: "Github",
    url: "github.com/Anth1818",
    href: "https://github.com/Anth1818"
  },
  location: {
    label: lang === "es" ? "Ubicación" : "Location",
    value: "Caracas, Venezuela"
  }
}
---

<LayoutSection
  title={lang === "es" ? "Contáctame" : "Contact Me"}
  colorSection="section-primary"
  id="contact"
>
  <MotionSection client:load className="container mx-auto max-w-6xl w-full mt-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Contact Info -->
      <div class="flex flex-col gap-6">
        <div class="glass-card p-8 rounded-3xl flex items-center gap-6 group hover:bg-white/10 transition-all duration-300">
          <div class="w-14 h-14 rounded-2xl bg-white/5 flex items-center justify-center group-hover:orange-gradient transition-all duration-500">
            <Icon name="Linkedin" class="w-7 h-7" />
          </div>
          <div class="flex-1 overflow-hidden">
            <p class="text-sm text-neutral-400 font-medium mb-1">{contactInfo.linkedin.label}</p>
            <p class="text-white font-bold truncate" id="linkedin-text">{contactInfo.linkedin.url}</p>
          </div>
          <button id="linkedin-copy" class="p-2 rounded-xl bg-white/5 hover:bg-white/10 text-neutral-400 hover:text-white transition-all cursor-pointer" title="Copy">
            <Icon name="Clipboard" class="w-5 h-5" />
          </button>
        </div>

        <div class="glass-card p-8 rounded-3xl flex items-center gap-6 group hover:bg-white/10 transition-all duration-300">
          <div class="w-14 h-14 rounded-2xl bg-white/5 flex items-center justify-center group-hover:orange-gradient transition-all duration-500">
            <Icon name="Github" class="w-7 h-7" />
          </div>
          <div class="flex-1 overflow-hidden">
            <p class="text-sm text-neutral-400 font-medium mb-1">{contactInfo.github.label}</p>
            <p class="text-white font-bold truncate" id="github-text">{contactInfo.github.url}</p>
          </div>
          <button id="github-copy" class="p-2 rounded-xl bg-white/5 hover:bg-white/10 text-neutral-400 hover:text-white transition-all cursor-pointer" title="Copy">
            <Icon name="Clipboard" class="w-5 h-5" />
          </button>
        </div>

        <div class="glass-card p-8 rounded-3xl flex items-center gap-6 group hover:bg-white/10 transition-all duration-300">
          <div class="w-14 h-14 rounded-2xl bg-white/5 flex items-center justify-center group-hover:orange-gradient transition-all duration-500">
            <Icon name="location" class="w-7 h-7" />
          </div>
          <div>
            <p class="text-sm text-neutral-400 font-medium mb-1">{contactInfo.location.label}</p>
            <p class="text-white font-bold">{contactInfo.location.value}</p>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="glass-card p-8 md:p-10 rounded-3xl">
        <ContactForm client:load lang={lang}/>
      </div>
    </div>
  </MotionSection>
</LayoutSection>

<script>
  function copyToClipboard(textId: string, buttonId: string) {
    const textElement = document.getElementById(textId);
    const button = document.getElementById(buttonId);
    
    if (textElement && button) {
      const text = textElement.innerText;
      navigator.clipboard.writeText(text).then(() => {
        const originalHtml = button.innerHTML;
        button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-green-500"><polyline points="20 6 9 17 4 12"></polyline></svg>';
        setTimeout(() => {
          button.innerHTML = originalHtml;
        }, 2000);
      });
    }
  }

  document.getElementById("linkedin-copy")?.addEventListener("click", () => copyToClipboard("linkedin-text", "linkedin-copy"));
  document.getElementById("github-copy")?.addEventListener("click", () => copyToClipboard("github-text", "github-copy"));
</script>
