---
import LayoutSection from "../../layouts/LayoutSection.astro";
import AppFolder from "../AppFolder.astro";

const { lang } = Astro.props;

const stackItems = [
  { iconName: "Html5", label: "HTML" },
  { iconName: "Css3", label: "CSS" },
  { iconName: "Javascript", label: "JavaScript" },
  { iconName: "Tailwind", label: "Tailwind" },
  { iconName: "Typescript", label: "TypeScript" },
  { iconName: "React", label: "React" },
  { iconName: "Nextjs", label: "Next.js" },
  { iconName: "Astro", label: "Astro" },
  { iconName: "Nodejs", label: "Node.js" },
  { iconName: "Express", label: "Express" },
  { iconName: "Prisma", label: "Prisma" },
  { iconName: "PostgreSQL", label: "PostgreSQL" },
];

const toolItems = [
  { iconName: "Vite", label: "Vite" },
  { iconName: "Git", label: "Git" },
  { iconName: "MdiGithub", label: "GitHub" },
  { iconName: "githubcopilot", label: "GitHub Copilot" },
  { iconName: "gemini", label: "Gemini" },
];
---

<LayoutSection
  title={lang === "es" ? "Tecnologías" : "Technologies"}
  colorSection="section-primary"
  id="technologies"
>
  <div class="container mx-auto max-w-6xl grid grid-cols-1 lg:grid-cols-2 gap-12 mt-4">
    <!-- Stack Card -->
    <div class="glass-card p-10 rounded-3xl flex flex-col items-center text-center">
      <div class="w-16 h-16 rounded-2xl orange-gradient flex items-center justify-center mb-6 shadow-lg shadow-orange-500/20">
        <span class="text-2xl font-bold">01</span>
      </div>
      <h3 class="text-3xl font-bold mb-4 text-gradient">Stack</h3>
      <p class="text-neutral-400 mb-10 max-w-md">
        {
          lang === "es"
            ? "Estas son algunas de las tecnologías web con las que he trabajado:"
            : "Here are some of the web technologies I work with:"
        }
      </p>

      <AppFolder folderName="Stack" items={stackItems} />
    </div>

    <!-- Tools Card -->
    <div class="glass-card p-10 rounded-3xl flex flex-col items-center text-center">
      <div class="w-16 h-16 rounded-2xl bg-neutral-800 border border-white/10 flex items-center justify-center mb-6 shadow-lg">
        <span class="text-2xl font-bold">02</span>
      </div>
      <h3 class="text-3xl font-bold mb-4 text-gradient">
        {lang === "es" ? "Herramientas" : "Tools"}
      </h3>
      <p class="text-neutral-400 mb-10 max-w-md">
        {
          lang === "es"
            ? "Estas son algunas de las herramientas de desarrollo e inteligencia artificial con las que he trabajado:"
            : "Here are some of the development and AI tools I work with:"
        }
      </p>

      <AppFolder folderName={lang === "es" ? "Herramientas" : "Tools"} items={toolItems} />
    </div>
  </div>
</LayoutSection>
