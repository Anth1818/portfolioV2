---
import logo from "src/icons/AR.Dev.svg"
import Language from "./Language.astro";

const {lang} = Astro.props

const contenNav = {
  labelEs: {
    home: "Inicio",
    about: "Sobre mí",
    projects: "Proyectos",
    technologies: "Tecnologías",
    softSkills: "Soft Skills",
    contact: "Contáctame",
    english:"Inglés"
  },
  labelEn: {
    home: "Home",
    about: "About me",
    projects: "Projects",
    technologies: "Technologies",
    softSkills: "Soft Skills",
    contact: "Contact me",
    spanish: "Spanish"
  }
}
---

<nav
    class="hidden lg:flex fixed top-0 left-0 w-full h-20 items-center justify-between px-10 glass z-50 transition-all duration-300">
      <div class="flex items-center gap-2">
        <img src={logo.src} alt="logo" class="w-12 h-12" />
      </div>
      
      <div class="flex items-center gap-12">
        <ul class="flex gap-8 items-center font-medium">
          <li><a class="nav-link" href="#home">{lang === "es" ? contenNav.labelEs.home : contenNav.labelEn.home}</a></li>
          <li><a class="nav-link" href="#about">{lang === "es" ? contenNav.labelEs.about : contenNav.labelEn.about}</a></li>
          <li><a class="nav-link" href="#projects">{lang === "es" ? contenNav.labelEs.projects : contenNav.labelEn.projects}</a></li>
          <li><a class="nav-link" href="#technologies">{lang === "es" ? contenNav.labelEs.technologies : contenNav.labelEn.technologies}</a></li>
          <li><a class="nav-link" href="#soft-skills">{lang === "es" ? contenNav.labelEs.softSkills : contenNav.labelEn.softSkills}</a></li>
        </ul>
  
        <div class="flex items-center gap-6">
          <a
            href="#contact"
            class="px-6 py-2 rounded-full orange-gradient text-white font-semibold text-center hover:scale-105 hover:shadow-lg hover:shadow-orange-500/20 transition-all duration-300"
          >
            {lang === "es" ? contenNav.labelEs.contact : contenNav.labelEn.contact}
          </a>
          <Language lang={lang} />
        </div>
      </div>
  </nav>

