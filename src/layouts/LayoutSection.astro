---
const {title, colorSection, id} = Astro.props
const arrayTitle = title.split(' ')
const phraseModified = arrayTitle.length === 1 ? false : arrayTitle[arrayTitle.length - 1]
const titleModified = arrayTitle.filter((word: string) => word !== phraseModified).join(' ')
---

<section
  id={id}
  class={`w-full py-24 px-6 bg-${colorSection} text-white`}
>
  <div class="flex flex-col items-center text-center">
    <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
      {titleModified} <span class="text-tertiary-400">{phraseModified}</span>
    </h2>
    <div class="w-20 h-1 orange-gradient rounded-full"></div>
  </div>
  <slot></slot>
</section>
